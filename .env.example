NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Dev only: one-click "Super Admin" on /login (omit or set false for production builds)
# Create the same user in Supabase: Authentication > Users > Add user > set email + password > Auto Confirm User
NEXT_PUBLIC_ENABLE_DEV_SUPER_ADMIN=false
NEXT_PUBLIC_DEV_SUPER_ADMIN_EMAIL=superadmin@ledgerview.local
NEXT_PUBLIC_DEV_SUPER_ADMIN_PASSWORD=change-me
